# Database
DATABASE_URL="postgresql://hall3:hall3dev@localhost:5432/hall3_points?schema=public"

# NextAuth
AUTH_SECRET="change-me-in-production-use-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Redis (BullMQ)
REDIS_URL="redis://localhost:6379"

# S3 / MinIO (local dev)
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
S3_BUCKET="hall3-uploads"
S3_FORCE_PATH_STYLE="true"

# Email (optional - magic link disabled if not set)
# RESEND_API_KEY=
# EMAIL_FROM="Hall 3 Portal <noreply@example.com>"
USE_LOCAL_STORAGE=true
ENABLE_QUEUE=false
